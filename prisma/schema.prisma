generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ===================== ADMIN AUTH =====================
model AdminUser {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  password  String
  isAdmin   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===================== CATEGORIES =====================
model Category {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  name          String        @unique
  slug          String        @default("")
  formerSlugs   String[]      @default([])
  description   String        @default("")
  image         String        @default("")
  metaTitle     String        @default("")
  metaDesc      String        @default("")
  sortOrder     Int           @default(0)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  subcategories Subcategory[]
  products      Product[]

  @@index([sortOrder])
  @@index([isActive])
}

// ===================== SUBCATEGORIES =====================
model Subcategory {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String    @default("")
  formerSlugs String[]  @default([])
  description String    @default("")
  image       String    @default("")
  metaTitle   String    @default("")
  metaDesc    String    @default("")
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  categoryId  String    @db.ObjectId
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@unique([name, categoryId])
  @@index([categoryId])
  @@index([order])
  @@index([isActive])
}

// ===================== PRODUCTS =====================
model Product {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  slug           String       @unique
  formerSlugs    String[]     @default([])
  description    String       @default("")
  image          String       @default("")
  images         String[]     @default([])
  metaTitle      String       @default("")
  metaDesc       String       @default("")
  isActive       Boolean      @default(true)
  tags           String[]     @default([])
  hasVariants    Boolean      @default(false)
  variantOptions Json         @default("[]")
  variants       Json         @default("[]")
  specs          Json         @default("[]")
  guarantee      String       @default("")
  categoryId     String       @db.ObjectId
  category       Category     @relation(fields: [categoryId], references: [id])
  subcategoryId  String?      @db.ObjectId
  subcategory    Subcategory? @relation(fields: [subcategoryId], references: [id])
  heroVideos     HeroVideo[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([categoryId])
  @@index([subcategoryId])
  @@index([isActive])
  @@index([isActive, categoryId])
}

// ===================== HERO VIDEOS =====================
model HeroVideo {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  description     String   @default("")
  videoUrl        String
  thumbnailUrl    String   @default("")
  order           Int      @default(0)
  isActive        Boolean  @default(true)
  duration        Int      @default(0)
  linkedProductId String?  @db.ObjectId
  linkedProduct   Product? @relation(fields: [linkedProductId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([order])
  @@index([isActive])
}

// ===================== ENQUIRIES =====================
enum EnquiryStatus {
  NEW
  CONTACTED
  CLOSED
}

model Enquiry {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String        @default("")
  phone     String
  company   String        @default("")
  product   String        @default("")
  quantity  String        @default("")
  message   String        @default("")
  status    EnquiryStatus @default(NEW)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ===================== BLOG CATEGORIES =====================
model BlogCategory {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  name      String     @unique
  slug      String     @unique
  order     Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  posts     BlogPost[]

  @@index([order])
  @@index([isActive])
}

// ===================== BLOG POSTS =====================
model BlogPost {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  slug          String        @unique
  formerSlugs   String[]      @default([])
  excerpt       String        @default("")
  content       String        @default("")
  category      String        @default("other")
  categoryId    String?       @db.ObjectId
  blogCategory  BlogCategory? @relation(fields: [categoryId], references: [id])
  tags          String[]      @default([])
  featuredImage String        @default("")
  featuredAlt   String        @default("")
  metaTitle     String        @default("")
  metaDesc      String        @default("")
  metaUrl       String        @default("")
  isPublished   Boolean       @default(false)
  readTime      Int           @default(5)
  author        String        @default("Garud Aqua Team")
  publishedAt   DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([isPublished])
  @@index([category])
  @@index([categoryId])
  @@index([publishedAt])
  @@index([isPublished, publishedAt])
}

// ===================== GALLERY ITEMS =====================
enum MediaType {
  IMAGE
  VIDEO
}

model GalleryItem {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  description  String    @default("")
  alt          String    @default("")
  mediaType    MediaType @default(IMAGE)
  mediaUrl     String
  thumbnailUrl String    @default("")
  order        Int       @default(0)
  isActive     Boolean   @default(true)
  tags         String[]  @default([])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([order])
  @@index([isActive])
  @@index([mediaType])
}

// ===================== HERO SLIDES =====================
model HeroSlide {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  image       String
  mobileImage String   @default("")
  title       String   @default("")
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
  @@index([isActive])
}
